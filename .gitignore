# Environment
.env
.env.local
.env.*.local

# Backend build artifacts
backend/build/
backend/.gradle/
backend/bin/
*.war
# Ignore JARs except the Gradle wrapper (needed for Docker builds)
*.jar
!backend/gradle/wrapper/gradle-wrapper.jar

# Frontend build artifacts
frontend/.next/
frontend/node_modules/
frontend/out/
frontend/.env.local

# IDE
.idea/
*.iml
.vscode/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Android local config
android/local.properties
android/.gradle/
android/app/build/
android/build/
android/**/*.apk
android/**/*.aab

# Logs
*.log
logs/

# Firebase credentials (keep locally, never commit)
backend/src/main/resources/*-firebase-adminsdk-*.json
backend/src/main/resources/firebase-service-account*.json

# Android signing keystore (keep locally, never commit)
android/*.jks
android/*.keystore
